<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="DesktopIcons.App.Dialogs.NameInputDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    CornerRadius="14"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="None"
    IsPrimaryButtonEnabled="False"
    PrimaryButtonStyle="{StaticResource PrimaryButton}"
    CloseButtonStyle="{StaticResource SecondaryButton}">

    <StackPanel Spacing="10" MinWidth="320">
        <TextBlock x:Name="HintText"
                   Style="{StaticResource CaptionText}" />
        <TextBox x:Name="NameBox"
                 PlaceholderText="e.g. Work setup"
                 MaxLength="64"
                 CornerRadius="7"
                 TextChanged="NameBox_TextChanged" />
        <TextBlock x:Name="ErrorText"
                   Foreground="{StaticResource DestructiveBrush}"
                   Style="{StaticResource CaptionText}"
                   Visibility="Collapsed" />
    </StackPanel>
</ContentDialog>
