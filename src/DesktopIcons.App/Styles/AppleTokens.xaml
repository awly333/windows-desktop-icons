<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==== Colors (Apple-inspired, light only) ==== -->
    <Color x:Key="WindowBackgroundColor">#F5F5F7</Color>
    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
    <Color x:Key="CardBackgroundHoverColor">#FAFAFA</Color>
    <Color x:Key="CardBackgroundSelectedColor">#F0F0F2</Color>
    <Color x:Key="SeparatorColor">#E5E5EA</Color>
    <Color x:Key="LabelColor">#1D1D1F</Color>
    <Color x:Key="SecondaryLabelColor">#6E6E73</Color>
    <Color x:Key="TertiaryLabelColor">#A1A1A6</Color>
    <Color x:Key="AccentBlueColor">#0071E3</Color>
    <Color x:Key="AccentBlueHoverColor">#0077ED</Color>
    <Color x:Key="DestructiveColor">#FF3B30</Color>
    <Color x:Key="MonitorFrameColor">#C7C7CC</Color>
    <Color x:Key="IconDotColor">#0071E3</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="CardBackgroundHoverBrush" Color="{StaticResource CardBackgroundHoverColor}" />
    <SolidColorBrush x:Key="CardBackgroundSelectedBrush" Color="{StaticResource CardBackgroundSelectedColor}" />
    <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}" />
    <SolidColorBrush x:Key="LabelBrush" Color="{StaticResource LabelColor}" />
    <SolidColorBrush x:Key="SecondaryLabelBrush" Color="{StaticResource SecondaryLabelColor}" />
    <SolidColorBrush x:Key="TertiaryLabelBrush" Color="{StaticResource TertiaryLabelColor}" />
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlueColor}" />
    <SolidColorBrush x:Key="AccentBlueHoverBrush" Color="{StaticResource AccentBlueHoverColor}" />
    <SolidColorBrush x:Key="DestructiveBrush" Color="{StaticResource DestructiveColor}" />
    <SolidColorBrush x:Key="MonitorFrameBrush" Color="{StaticResource MonitorFrameColor}" />
    <SolidColorBrush x:Key="IconDotBrush" Color="{StaticResource IconDotColor}" />

    <CornerRadius x:Key="RadiusSmall">6</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">10</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">14</CornerRadius>

    <x:Double x:Key="Space4">4</x:Double>
    <x:Double x:Key="Space8">8</x:Double>
    <x:Double x:Key="Space12">12</x:Double>
    <x:Double x:Key="Space16">16</x:Double>
    <x:Double x:Key="Space24">24</x:Double>

    <x:String x:Key="FontFamilySystem">Segoe UI Variable, Segoe UI</x:String>

    <Style x:Key="Title1Text" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySystem}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
    </Style>

    <Style x:Key="HeadlineText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySystem}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
    </Style>

    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySystem}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
    </Style>

    <Style x:Key="CaptionText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySystem}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource SecondaryLabelBrush}" />
    </Style>

    <!-- Button styles set Background/Foreground via Setter; the WinUI Button template's
         VSM still applies the default hover/pressed brightness adjustments on top. -->

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBlueBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySystem}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Padding" Value="14,6,14,6" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySystem}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Padding" Value="14,6,14,6" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource SeparatorBrush}" />
    </Style>

    <Style x:Key="DestructiveButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="Foreground" Value="{StaticResource DestructiveBrush}" />
    </Style>

    <Style x:Key="PrimaryDestructiveButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource DestructiveBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySystem}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="Padding" Value="14,6,14,6" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style x:Key="IconCircleButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource LabelBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilySystem}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource SeparatorBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
