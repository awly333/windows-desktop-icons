<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DesktopIcons.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:DesktopIcons.App.Controls"
    xmlns:vm="using:DesktopIcons.App.ViewModels"
    xmlns:tb="using:H.NotifyIcon">

    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ==== Title bar ==== -->
        <Grid Grid.Row="0" Padding="20,16,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Desktop Icons"
                           Style="{StaticResource Title1Text}" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE7F4;"
                              FontSize="12"
                              Foreground="{StaticResource TertiaryLabelBrush}"
                              VerticalAlignment="Center" />
                    <TextBlock x:Name="FingerprintText"
                               Text="{x:Bind ViewModel.DisplaySummary, Mode=OneWay}"
                               Style="{StaticResource CaptionText}"
                               TextTrimming="CharacterEllipsis"
                               ToolTipService.ToolTip="{x:Bind ViewModel.CurrentSetup, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Style="{StaticResource IconCircleButton}"
                        ToolTipService.ToolTip="Save current desktop"
                        Click="NewLayout_Click">
                    <FontIcon Glyph="&#xE710;" FontSize="10" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- ==== List ==== -->
        <ScrollViewer Grid.Row="1" Padding="16,0,16,16"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="8"
                            MinHeight="300"
                            Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}">
                    <TextBlock Text="No saved layouts"
                               HorizontalAlignment="Center"
                               Style="{StaticResource HeadlineText}" />
                    <TextBlock Text="Tap + to save the current desktop"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource SecondaryLabelBrush}"
                               Style="{StaticResource BodyText}" />
                </StackPanel>

                <!-- Card list -->
                <ItemsControl x:Name="LayoutList"
                              ItemsSource="{x:Bind ViewModel.Layouts, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.LayoutsVisibility, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:LayoutItemViewModel">
                            <Grid Background="{StaticResource CardBackgroundBrush}"
                                  CornerRadius="10"
                                  Padding="12"
                                  BorderBrush="{StaticResource SeparatorBrush}"
                                  BorderThickness="1"
                                  PointerPressed="Card_PointerPressed"
                                  Tag="{x:Bind}">

                                <StackPanel Spacing="10">
                                    <!-- Collapsed row: thumbnail + name + time -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="96" Height="60"
                                                CornerRadius="6"
                                                Background="{StaticResource WindowBackgroundBrush}"
                                                Margin="0,0,12,0">
                                            <controls:LayoutPreviewCanvas
                                                Layout="{x:Bind Layout, Mode=OneWay}"
                                                DotSize="2.5" />
                                        </Border>

                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name}"
                                                       Style="{StaticResource HeadlineText}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Style="{StaticResource CaptionText}">
                                                <Run Text="{x:Bind CapturedAtDisplay}" />
                                                <Run Text="  ·  " />
                                                <Run Text="{x:Bind IconCount}" /><Run Text=" icons" />
                                            </TextBlock>
                                        </StackPanel>

                                        <FontIcon Grid.Column="2"
                                                  Glyph="&#xE76C;"
                                                  FontSize="12"
                                                  Foreground="{StaticResource TertiaryLabelBrush}"
                                                  VerticalAlignment="Center"
                                                  Visibility="{x:Bind CollapsedVisibility, Mode=OneWay}" />
                                        <FontIcon Grid.Column="2"
                                                  Glyph="&#xE70D;"
                                                  FontSize="12"
                                                  Foreground="{StaticResource TertiaryLabelBrush}"
                                                  VerticalAlignment="Center"
                                                  Visibility="{x:Bind ExpandedVisibility, Mode=OneWay}" />
                                    </Grid>

                                    <!-- Expanded body: big preview + actions -->
                                    <StackPanel Spacing="10"
                                                Visibility="{x:Bind ExpandedVisibility, Mode=OneWay}">
                                        <Border Height="160"
                                                CornerRadius="8"
                                                Background="{StaticResource WindowBackgroundBrush}">
                                            <controls:LayoutPreviewCanvas
                                                Layout="{x:Bind Layout, Mode=OneWay}"
                                                DotSize="6" />
                                        </Border>

                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                            <Button Style="{StaticResource DestructiveButton}"
                                                    Content="Delete"
                                                    Tag="{x:Bind}"
                                                    Click="Delete_Click" />
                                            <Button Style="{StaticResource SecondaryButton}"
                                                    Content="Rename"
                                                    Tag="{x:Bind}"
                                                    Click="Rename_Click" />
                                            <Button Style="{StaticResource PrimaryButton}"
                                                    Content="Restore"
                                                    Tag="{x:Bind}"
                                                    Click="Restore_Click" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- ==== Tray icon (non-visual; IconSource set in code-behind) ==== -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="Desktop Icons"
                        NoLeftClickDelay="True"
                        LeftClickCommand="{x:Bind ToggleTrayCommand}">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <ToggleMenuFlyoutItem Text="Start with Windows"
                                          IsChecked="{x:Bind Settings.StartWithWindows, Mode=OneWay}"
                                          Command="{x:Bind ToggleStartWithWindowsCommand}" />
                    <ToggleMenuFlyoutItem Text="Close to tray"
                                          IsChecked="{x:Bind Settings.CloseToTray, Mode=OneWay}"
                                          Command="{x:Bind ToggleCloseToTrayCommand}" />
                    <ToggleMenuFlyoutItem Text="Auto-restore on display change"
                                          IsChecked="{x:Bind Settings.AutoRestoreOnDisplayChange, Mode=OneWay}"
                                          Command="{x:Bind ToggleAutoRestoreCommand}" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Quit" Command="{x:Bind QuitCommand}" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>

        <!-- ==== Toast ==== -->
        <Border Grid.Row="1"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="16,0,16,20"
                Background="#1D1D1F"
                CornerRadius="10"
                Padding="14,8,14,8"
                Visibility="{x:Bind ViewModel.ToastVisibility, Mode=OneWay}">
            <TextBlock Text="{x:Bind ViewModel.ToastMessage, Mode=OneWay}"
                       Foreground="White"
                       FontSize="13"
                       MaxWidth="440"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
